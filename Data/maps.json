{
  "knockout": {
    "out_in_the_open": {
      "title": "Out in the Open",
      "image": "media/maps/out_in_the_open.jpg",
      "description": "An open Knockout map with little cover. Long-range Brawlers dominate, while good positioning and center control are key to surviving until the poison closes in.",
      "picks": [
        {
          "name": "Toxic Ambush",
          "photo": "media/picks/knockout_p1(bkb).jpg",
          "brawlers": ["Byron", "Kit", "Bolt"],
          "description": "Play patiently and control the long sightlines. Byron should stay behind the team, constantly healing allies while poisoning enemies. Bolt holds open angles and applies steady pressure from range. Kit supports the strongest teammate, looking for opportunities to jump on weakened enemies or secure key eliminations. Avoid unnecessary fights early and use your range advantage to slowly wear the enemy team down."
        },
                {
          "name": "Deadeye Assault",
          "photo": "media/picks/knockout_p2(bep).jpg",
          "brawlers": ["Brock", "Edgar", "Piper"],
          "description": "Piper and Brock control the map from long range, forcing enemies out of position. Edgar should play patiently and only dive once an opponent is weakened or isolated. Keep your distance early and let Edgar clean up fights."
        },
        {
          "name": "Toxic Dominance",
          "photo": "media/picks/knockout_p3(nac).jpg",
          "brawlers": ["Angelo", "Colette", "Najia"],
          "description": "Use Angelo to dominate long sightlines while Colette chips down high-health targets. Najia provides extra pressure and helps secure eliminations. Focus on maintaining map control, winning ranged duels, and avoiding unnecessary close-range fights."
    }
      ]
    },
